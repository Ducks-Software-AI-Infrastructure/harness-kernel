---
const packages = [
  ["@harness-kernel/core", "Zero-dependency runtime contracts, sessions, events, schema, and memory/noop infrastructure."],
  ["@harness-kernel/provider-openai", "OpenAI model provider built on the AI SDK provider package."],
  ["@harness-kernel/provider-ai-sdk", "Generic model provider bridge for Vercel AI SDK language models."],
  ["@harness-kernel/storage-file", "File-backed run storage for transcripts, events, snapshots, metrics, and cursors."],
  ["@harness-kernel/sandbox-local", "Local shell sandbox owned by the host application."],
  ["@harness-kernel/tools-node", "Mode-owned Bash and filesystem tools for Node-based hosts."],
  ["@harness-kernel/skills", "Procedural skills with active prompts, control tools, soft-gated tools, events, and logs."],
  ["@harness-kernel/logging-file", "JSONL operational log sink for runtime-owned logging."],
  ["@harness-kernel/create", "Scaffold and devtool package. It is not hidden infrastructure."],
];
---

<div class="package-grid">
  {packages.map(([name, body]) => (
    <article>
      <h3>{name}</h3>
      <p>{body}</p>
    </article>
  ))}
</div>

<style>
  .package-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  article {
    min-width: 0;
    border: 1px solid rgba(245, 245, 240, 0.14);
    border-radius: 8px;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  h3 {
    margin: 0 0 0.6rem;
    color: #f5f5f0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  p {
    margin: 0;
    color: #b8b8ae;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  @media (max-width: 1050px) {
    .package-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .package-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
