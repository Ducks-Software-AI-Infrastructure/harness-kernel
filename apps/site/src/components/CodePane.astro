---
interface Props {
  label: string;
  caption?: string;
  code: string;
}

const { label, caption, code } = Astro.props;
---

<figure class="code-pane">
  <figcaption>
    <span>{label}</span>
    {caption && <small>{caption}</small>}
  </figcaption>
  <pre><code>{code.trim()}</code></pre>
</figure>

<style>
  .code-pane {
    min-width: 0;
    margin: 0;
    border: 1px solid rgba(245, 245, 240, 0.16);
    border-radius: 8px;
    overflow: hidden;
    background: #111110;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  figcaption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(245, 245, 240, 0.12);
    padding: 0.72rem 0.9rem;
    color: #f5f5f0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    line-height: 1.2;
  }

  small {
    color: #94948c;
    font: inherit;
    text-align: right;
  }

  pre {
    margin: 0;
    padding: 0.95rem;
    max-height: 36rem;
    overflow: auto;
    color: #ededdf;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    tab-size: 2;
  }

  code {
    font: inherit;
  }

  @media (max-width: 560px) {
    figcaption {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }

    small {
      text-align: left;
    }

    pre {
      font-size: 0.72rem;
      padding: 0.8rem;
    }
  }
</style>
