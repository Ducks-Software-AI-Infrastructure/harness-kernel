---
interface Props {
  label: string;
  status?: string;
}

const { label, status = "active" } = Astro.props;
---

<span class="terminal-label">
  <span class="terminal-dot" aria-hidden="true"></span>
  <span>{label}</span>
  <span class="terminal-status">{status}</span>
</span>

<style>
  .terminal-label {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    max-width: 100%;
    border: 1px solid rgba(245, 245, 240, 0.18);
    border-radius: 999px;
    padding: 0.34rem 0.62rem;
    color: #f5f5f0;
    background: rgba(255, 255, 255, 0.035);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.1;
    white-space: nowrap;
  }

  .terminal-dot {
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 999px;
    background: #8fe388;
    box-shadow: 0 0 0 2px rgba(143, 227, 136, 0.1);
  }

  .terminal-status {
    color: #9b9b94;
  }
</style>
