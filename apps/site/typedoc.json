{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "tsconfig": "tsconfig.typedoc.json",
  "entryPoints": [
    "../../packages/core/src/index.ts",
    "../../packages/core/src/exports/agent.ts",
    "../../packages/core/src/exports/agent/mode.ts",
    "../../packages/core/src/exports/agent/tool.ts",
    "../../packages/core/src/exports/agent/context.ts",
    "../../packages/core/src/exports/agent/hook.ts",
    "../../packages/core/src/exports/agent/role.ts",
    "../../packages/core/src/exports/agent/event.ts",
    "../../packages/core/src/exports/agent/session.ts",
    "../../packages/core/src/exports/runner.ts",
    "../../packages/core/src/exports/runner/model-provider.ts",
    "../../packages/core/src/exports/runner/storage.ts",
    "../../packages/core/src/exports/runner/sandbox.ts",
    "../../packages/core/src/exports/runner/approval.ts",
    "../../packages/core/src/exports/runner/logging.ts",
    "../../packages/core/src/exports/runner/event.ts",
    "../../packages/core/src/schema/index.ts",
    "../../packages/provider-openai/src/index.ts",
    "../../packages/provider-ai-sdk/src/index.ts",
    "../../packages/storage-file/src/index.ts",
    "../../packages/sandbox-local/src/index.ts",
    "../../packages/tools-node/src/index.ts",
    "../../packages/tools-node/src/bash.ts",
    "../../packages/tools-node/src/files.ts",
    "../../packages/logging-file/src/index.ts",
    "../../packages/create/src/index.ts"
  ],
  "out": ".typedoc/api-reference-raw",
  "plugin": ["typedoc-plugin-markdown"],
  "entryFileName": "index",
  "fileExtension": ".md",
  "readme": "none",
  "cleanOutputDir": true,
  "gitRevision": "main",
  "excludePrivate": true,
  "excludeProtected": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "parametersFormat": "table",
  "interfacePropertiesFormat": "table",
  "classPropertiesFormat": "table",
  "typeAliasPropertiesFormat": "table",
  "enumMembersFormat": "table"
}
