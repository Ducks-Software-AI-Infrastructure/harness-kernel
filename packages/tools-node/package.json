{
  "name": "@harness-kernel/tools-node",
  "version": "0.1.0",
  "type": "module",
  "description": "Node-oriented tools for Harness Kernel modes.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ducks-Software-AI-Infrastructure/harness-kernel.git"
  },
  "homepage": "https://ducks-software-ai-infrastructure.github.io/harness-kernel/docs/packages/tools-node/",
  "bugs": {
    "url": "https://github.com/Ducks-Software-AI-Infrastructure/harness-kernel/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "typescript",
    "harness-kernel",
    "tools",
    "node",
    "sandbox"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bash": {
      "types": "./dist/bash.d.ts",
      "import": "./dist/bash.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "import": "./dist/files.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/tools-node.test.ts"
  },
  "dependencies": {
    "@harness-kernel/core": "0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
